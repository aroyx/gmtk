[editor]

movie_writer/size/mode=0
movie_writer/size/resizable=true

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[global_group]

hiding_places="These are the entities where the player can hide"
