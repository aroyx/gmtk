config_version=5

[application]

config/name="GMTK"
run/main_scene="uid://bb0738xhrqnlr"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

DialogueManager="*uid://d0ncpcbyvhna4"
UiSound="*uid://b2mxwsl2ojrbm"

[display]

window/size/resizable=false
window/stretch/mode="canvas_items"
